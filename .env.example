# Copy this file to .env (gitignored) and fill in real values, then run:
#
#   flutter run --dart-define-from-file=.env
#
# CI uses the same variable names as GitHub Actions secrets
# (repo Settings -> Secrets and variables -> Actions).

# Anthropic API key for the Claude translation path (console.anthropic.com).
ANTHROPIC_API_KEY=sk-ant-...

# HTTPS URL of the deployed Cloud Function (backend/google_function).
GOOGLE_BACKEND_URL=https://REGION-PROJECT.cloudfunctions.net/subtitle-translator

# Shared secret for that function; must match its BACKEND_API_KEY env var.
# Generate one with: openssl rand -hex 24
GOOGLE_BACKEND_API_KEY=
